{
  "name": "@dangoldbj/openclaw-simplex",
  "version": "0.2.0",
  "description": "SimpleX channel plugin for OpenClaw",
  "homepage": "https://dangoldbj.github.io/openclaw-simplex/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dangoldbj/openclaw-simplex.git"
  },
  "bugs": {
    "url": "https://github.com/dangoldbj/openclaw-simplex/issues"
  },
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.17.1",
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup index.ts --format esm --dts --clean",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm run test && pnpm run typecheck && pnpm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.22"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.3.0",
    "@types/qrcode": "^1.5.5",
    "@types/ws": "^8.18.1",
    "openclaw": "^2026.3.22",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.4"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "channel": {
      "id": "simplex",
      "label": "SimpleX",
      "selectionLabel": "SimpleX (CLI)",
      "docsPath": "/channels/simplex",
      "docsLabel": "simplex",
      "blurb": "SimpleX Chat over CLI WebSocket API.",
      "order": 95,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@dangoldbj/openclaw-simplex",
      "defaultChoice": "npm"
    }
  }
}
